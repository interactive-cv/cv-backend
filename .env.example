# ---- z.ai ----
# ВАЖНО: подписка GLM Coding Plan работает ТОЛЬКО через coding-эндпоинт
# (https://api.z.ai/api/coding/paas/v4), НЕ через стандартный /api/paas/v4.
# Поддерживаемые модели: glm-4.7 (рекоменд., 1× квоты), GLM-5-Turbo, GLM-5.2 (2-3× квоты).
ZAI_API_KEY=your-zai-key-here
ZAI_API_BASE=https://api.z.ai/api/coding/paas/v4
ZAI_MODEL=glm-4.7

# ---- Rate limit ----
CHAT_RATE_PER_HOUR=50
CHAT_RATE_PER_DAY=300
